# Copy these into Vercel → Project → Settings → Environment Variables.
# Do NOT commit a real .env — this file is just the template.

# Your registered LI.FI integrator string (from portal.li.fi).
INTEGRATOR=x1-teleporter-labs

# Integrator fee as a float. 0.01 = 1%. LI.FI max is 0.10 (10%).
INTEGRATOR_FEE=0.01

# Optional: LI.FI API key — raises rate limit from 200/2h to 200/min.
LIFI_API_KEY=

# Fee payout wallets. EVM-settled fees go to the EVM address; Solana/X1-settled
# fees go to the SVM address. Used by the withdraw flow (server never signs).
FEE_WALLET_EVM=
FEE_WALLET_SVM=
